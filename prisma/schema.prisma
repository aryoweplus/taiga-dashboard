generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// Konfigurasi koneksi Taiga per project
model TaigaConnection {
  id          Int      @id @default(autoincrement())
  projectName String
  baseUrl     String
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  taigaUserId Int      @unique
  fullName    String
  username    String
  role        String
  color       String   @default("#1a56db")
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WidgetConfig {
  id        Int      @id @default(autoincrement())
  widgetKey String   @unique
  visible   Boolean  @default(true)
  position  Int      @default(0)
  chartType String   @default("bar")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SprintSnapshot {
  id           Int      @id @default(autoincrement())
  projectId    String
  sprintId     Int
  sprintName   String
  doneCount    Int
  inProgress   Int
  blockedCount Int
  totalCount   Int
  takenAt      DateTime @default(now())

  @@unique([projectId, sprintId, takenAt])
  @@index([projectId, sprintId])
}